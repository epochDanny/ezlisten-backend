PORT=3000
NODE_ENV=development

# MongoDB Connection
# Use one of these (MONGO_URL, MONGODB_URL, or MONGODB_URI)
# For local development: mongodb://localhost:27017/ezlisten
# For production: your MongoDB connection string from your hosting provider
MONGO_URL=mongodb://localhost:27017/ezlisten
# MONGODB_URL=your_mongodb_url_here
# MONGODB_URI=your_mongodb_uri_here

JWT_SECRET=change-me-in-production
PUBLIC_BASE_URL=http://localhost:3000
